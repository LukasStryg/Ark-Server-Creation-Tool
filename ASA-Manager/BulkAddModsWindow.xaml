<Window x:Class="ARKServerCreationTool.BulkAddModsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk add mods" Height="360" Width="480" MinHeight="260" MinWidth="360">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,6"
                   Text="Paste CurseForge Project IDs or mod URLs — one per line, or comma/space separated. Slug-only URLs without a number are skipped."/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="btn_paste" Content="Paste from clipboard" Height="24" Margin="0,0,6,0" Click="btn_paste_Click"/>
            <Button x:Name="btn_import" Content="Import .txt…" Height="24" Click="btn_import_Click"/>
        </StackPanel>
        <TextBox x:Name="txt_bulk" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="btn_ok" Content="Add" Width="80" Height="26" Margin="0,0,6,0" Click="btn_ok_Click"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80" Height="26" Click="btn_cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
