<Window x:Name="btn_saveConfig" x:Class="ARKServerCreationTool.ServerConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ARKServerCreationTool"
        mc:Ignorable="d"
        Title="ASCT - Server Configuration" Height="713" MinHeight="516" Width="520" MinWidth="520">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Label Content="Server Configuration" HorizontalAlignment="Left" Margin="10,10,0,10" FontSize="16"/>
            <Button x:Name="btn_save" Content="Save" Margin="0,10,10,10" Click="btn_save_Click" HorizontalAlignment="Right" Width="135"/>
        </Grid>

        <!-- Form fields: a scrollable stack of label/field rows, top-anchored (auto-flow, never overlaps) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="10,0,10,0">

                <!-- Server Name -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Server Name" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="txt_serverName" ToolTip="Just a name used to identify the server within the tool" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                </Grid>

                <!-- Install Directory -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Install Directory" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txt_gameDir" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                        <Button Grid.Column="1" x:Name="btn_browse" Content="Browse..." Width="71" Height="26" Margin="6,0,0,0" Click="btn_browse_Click"/>
                    </Grid>
                </Grid>

                <!-- Map -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Map" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cmbo_Map" Height="26" VerticalContentAlignment="Center" SelectionChanged="comboSelectionChanged"/>
                        <TextBox Grid.Column="0" x:Name="txt_customMap" Height="26" Visibility="Collapsed" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                        <Button Grid.Column="1" x:Name="btn_newMap" Content="New Map..." Width="104" Height="26" Margin="6,0,0,0" Click="btn_newMap_Click"/>
                    </Grid>
                </Grid>

                <!-- Cluster ID -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Cluster ID" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cmbo_clusterKey" Height="26" SelectionChanged="comboSelectionChanged"/>
                        <TextBox Grid.Column="0" x:Name="txt_newClusterID" ToolTip="Enter a new cluster ID. This must be something unique amongst all ASA servers" Visibility="Collapsed" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                        <Button Grid.Column="1" x:Name="btn_newCluster" Content="New Cluster..." Width="104" Height="26" Margin="6,0,0,0" Click="btn_newCluster_Click"/>
                    </Grid>
                </Grid>

                <!-- Main Game Port -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Main Game Port" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox x:Name="txt_gamePort" Width="80" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged" PreviewTextInput="txt_gamePort_PreviewTextInput"/>
                        <Label x:Name="lbl_invalidPort" Content="⚠️ Invalid Value" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Max Players -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Max Players" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox x:Name="txt_slots" Width="80" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged" PreviewTextInput="txt_slot_PreviewTextInput"/>
                        <Label x:Name="lbl_invalidSlots" Content="⚠️ Invalid Value" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- RCON Port -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="RCON Port" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="txt_rconPort" Width="80" Height="26" HorizontalAlignment="Left" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                </Grid>

                <!-- Admin Password -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Admin Password" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txt_adminPassword" ToolTip="RCON/admin password (doubles as the RCON password). Stored in the tool's config." Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                        <Button Grid.Column="1" x:Name="btn_regenPassword" Content="Regenerate" Width="75" Height="26" Margin="6,0,0,0" Click="btn_regenPassword_Click"/>
                    </Grid>
                </Grid>

                <!-- Active Event -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Active Event" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="txt_activeEvent" Height="26" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                </Grid>

                <!-- Specify IP address (multihome) -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Specify IP address" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="chk_useMultiHome" VerticalAlignment="Center" Click="chk_useMultiHome_Checked"/>
                        <TextBox Grid.Column="1" x:Name="txt_multiHomeIPaddress" IsEnabled="False" Height="26" Margin="8,0,0,0" VerticalContentAlignment="Center" FontSize="12" TextChanged="TextChanged"/>
                    </Grid>
                </Grid>

                <!-- Allow Crossplay -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Allow Crossplay" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="chk_crossplay" VerticalAlignment="Center" Click="chk_crossplay_Checked"/>
                </Grid>

                <!-- No Battleye -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="No Battleye" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="chk_noBattleye" VerticalAlignment="Center" Click="chk_crossplay_Checked"/>
                </Grid>

                <!-- Automatic Start -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Automatic Start" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="chk_automaticStart" VerticalAlignment="Center" Click="chk_crossplay_Checked"/>
                </Grid>
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="1" x:Name="lbl_allowAutoLaunchDisabled" Content="⚠️ Automatic start is currently disabled globally." FontSize="10" Padding="0"/>
                </Grid>

                <!-- Exclude from bulk start -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="1" x:Name="chk_excludeBulkStart" Content="Exclude from Start All / Auto-Start" VerticalAlignment="Center"/>
                </Grid>

                <!-- Mods -->
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Mods" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="btn_manageMods" Content="Manage Mods…" Height="26" HorizontalAlignment="Left" Width="150" Click="btn_manageMods_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Launch Arguments: pinned to the bottom, separated from the fields above -->
        <StackPanel Grid.Row="2" Margin="10,4,10,10">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <CheckBox Grid.Column="1" x:Name="chkbx_overrideCommandline" Content="Manually define launch arguments" VerticalAlignment="Center" Click="chkbx_overrideCommandline_Click"/>
            </Grid>
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Launch Arguments" HorizontalContentAlignment="Right" VerticalAlignment="Top"/>
                <TextBox Grid.Column="1" x:Name="txt_commandLine" IsEnabled="False" TextWrapping="WrapWithOverflow" Height="63" FontSize="12" VerticalContentAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
